PORT=5000

# Local Windows (if mongodb+srv gives querySrv ECONNREFUSED):
MONGO_URI=mongodb://YOUR_USER:YOUR_PASSWORD@ac-xxxxx-shard-00-00.xxxxx.mongodb.net:27017/dealerwebsite?ssl=true&directConnection=true&authSource=admin&retryWrites=true&w=majority

# Render / cloud (use Atlas Connect → Drivers → copy mongodb+srv string):
# MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/dealerwebsite?retryWrites=true&w=majority

JWT_SECRET=change-this-to-a-long-random-string
